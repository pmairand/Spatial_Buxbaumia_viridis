# -----------------------------------------------------------------------------
# 7. Residual spatial autocorrelation - Moran's I test
# -----------------------------------------------------------------------------

# GLM residuals
res_glm <- residuals(result_GLM_INLA$glm, type = "pearson")
df_glm_res <- result_GLM_INLA$data %>% drop_na()
df_glm_res$res_glm <- res_glm
coords_glm <- as.matrix(df_glm_res[, c("X_loc", "Y_loc")])
nb_glm <- dnearneigh(coords_glm, 0, 30)
lw_glm <- nb2listw(nb_glm, style = "W")
mt_glm <- moran.test(df_glm_res$res_glm, lw_glm)

# INLA residuals
residuals_inla <- (result_GLM_INLA$pred$P_Bux - result_GLM_INLA$pred$p_inla) /
  sqrt(result_GLM_INLA$pred$p_inla * (1 - result_GLM_INLA$pred$p_inla))
coords_inla <- as.matrix(result_GLM_INLA$pred[, c("X_loc", "Y_loc")])
nb_inla <- dnearneigh(coords_inla, 0, 30)
lw_inla <- nb2listw(nb_inla, style = "W")
mt_inla <- moran.test(residuals_inla, lw_inla)

# Moran's I results table
moran_df <- data.frame(
  Model = c("GLM", "INLA"),
  Moran_I = c(
    mt_glm$estimate["Moran I statistic"],
    mt_inla$estimate["Moran I statistic"]
  ),
  Expectation = c(
    mt_glm$estimate["Expectation"],
    mt_inla$estimate["Expectation"]
  ),
  Variance = c(
    mt_glm$estimate["Variance"],
    mt_inla$estimate["Variance"]
  ),
  Z_score = c(
    mt_glm$statistic,
    mt_inla$statistic
  ),
  P_value = c(
    mt_glm$p.value,
    mt_inla$p.value
  )
)

tbl_moran <- moran_df %>%
  gt() %>%
  tab_header(title = "Moran's I test — residual spatial autocorrelation") %>%
  fmt_number(columns = c(Moran_I, Expectation, Variance, Z_score), decimals = 4) %>%
  fmt_scientific(columns = P_value, decimals = 3) %>%
  tab_style(
    style = list(cell_text(weight = "bold"), cell_fill(color = "#d9d9d9")),
    locations = cells_body(rows = P_value < 0.05)
  ) %>%
  tab_style(
    style = cell_fill(color = "#f5f5f5"),
    locations = cells_body(rows = seq(1, nrow(moran_df), 2))
  ) %>%
  tab_options(
    table.border.top.color            = "black",
    table.border.bottom.color         = "black",
    column_labels.border.bottom.color = "black",
    column_labels.font.weight         = "bold",
    table.font.size                   = 12
  )

tbl_moran

