    Z_value = statistic, P_value = p.value
  ) %>%
  gt() %>%
  tab_header(title = "GLM coefficients") %>%
  fmt_number(columns = c(Estimate, Std_Error, Z_value), decimals = 3) %>%
  fmt_scientific(columns = P_value, decimals = 3) %>%
  tab_style(
    style = cell_fill(color = "#f5f5f5"),
    locations = cells_body(rows = seq(1, nrow(glm_df), 2))
  ) %>%
  tab_options(
    table.border.top.color             = "black",
    table.border.bottom.color          = "black",
    column_labels.border.bottom.color  = "black",
    column_labels.font.weight          = "bold",
    table.font.size                    = 12
  )

tbl_glm

# INLA fixed effects table
tbl_inla <- inla_fixed %>%
